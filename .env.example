# Required for acceptance tests (make testacc)
COOLIFY_ENDPOINT="http://localhost:8000"
COOLIFY_TOKEN="<your-api-token-from-coolify-settings>"

# Required for Hetzner-related acceptance tests
# COOLIFY_HETZNER_TOKEN="<real-hetzner-api-token>"

# Optional: auto-discovered if not set
# COOLIFY_SERVER_UUID="<server-uuid>"

# Optional: GitHub App application tests (see TESTING.md)
# COOLIFY_GITHUB_APP_APP_ID=
# COOLIFY_GITHUB_APP_INSTALLATION_ID=
# COOLIFY_GITHUB_APP_CLIENT_ID=
# COOLIFY_GITHUB_APP_CLIENT_SECRET=
# COOLIFY_GITHUB_APP_WEBHOOK_SECRET=
# COOLIFY_GITHUB_APP_PRIVATE_KEY_UUID=
# COOLIFY_GITHUB_APP_ORGANIZATION=
# COOLIFY_GITHUB_APP_UUID=
